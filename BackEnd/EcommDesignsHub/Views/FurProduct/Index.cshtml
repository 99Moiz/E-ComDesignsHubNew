@model IEnumerable<FursonaHub.API.Models.Product>

@{
    ViewData["Title"] = "Fursona Products";
}

<div class="row page-header mt-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold section-title mb-0">Fursona <span style="color:var(--brand-lime)">Products</span></h2>
            <p class="text-secondary small mb-0">Manage products, gallery images, custom features, and specs.</p>
        </div>
        <a asp-action="Create" class="btn btn-theme">
            <i class="bi bi-plus-lg"></i> Add Product
        </a>
    </div>
</div>

<div class="card app-card mt-4 p-4">
    <div class="table-responsive">
        <table class="table table-dark table-striped table-hover table-modern mb-0">
            <thead>
                <tr>
                    <th scope="col" style="width: 80px;">Image</th>
                    <th scope="col">Title</th>
                    <th scope="col">Category</th>
                    <th scope="col">Price</th>
                    <th scope="col">Rating</th>
                    <th scope="col">Status</th>
                    <th scope="col">Sort</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-secondary py-4">No products found. Click "Add Product" to get started.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        var primaryImage = item.Gallery?.FirstOrDefault(g => g.IsPrimary)?.ImageUrl 
                                           ?? item.Gallery?.OrderBy(g => g.SortOrder).FirstOrDefault()?.ImageUrl
                                           ?? "/images/media.jfif"; // Default fallback
                        <tr>
                            <td>
                                <img src="@primaryImage" alt="@item.Title" class="img-thumbnail bg-dark border-secondary" style="width: 60px; height: 60px; object-fit: cover; border-radius: 6px;" />
                            </td>
                            <td>
                                <div class="fw-bold text-white">@item.Title</div>
                                <div class="text-secondary small">Slug: @item.Slug</div>
                            </td>
                            <td>
                                <span class="badge bg-dark border border-secondary text-light">@item.Category?.Name</span>
                            </td>
                            <td class="fw-bold text-white">$@item.Price.ToString("N2")</td>
                            <td>
                                <span class="text-warning"><i class="bi bi-star-fill me-1"></i>@item.Rating.ToString("F1")</span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactive</span>
                                }
                            </td>
                            <td>@item.SortOrder</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1">
                                    <i class="bi bi-eye"></i> Manage
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light me-1">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this product? All gallery images, specs, and features will also be deleted.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
