@using EcommDesignsHub.Models.ViewModel
@model JobApplicantsViewModel

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <h2 class="section-title">Approved Applicants for: @Model.Job.Title</h2>
    <div class="btn-group">
        <a asp-action="Applicants" asp-route-id="@Model.Job.JobId" class="btn btn-outline-light">All Applicants</a>
        <a asp-action="Details" asp-route-id="@Model.Job.JobId" class="btn btn-outline-light">Back to Job</a>
        <a asp-action="Index" class="btn btn-outline-light">All Jobs</a>
    </div>
</div>

@if (!Model.Applications.Any())
{
    <div class="alert alert-info">No approved applicants yet for this job.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Experience</th>
                    <th>Status</th>
                    <th>Applied Date</th>
                    <th>Resume</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model.Applications)
                {
                    <tr>
                        <td>@app.FullName</td>
                        <td>@app.Email</td>
                        <td>@app.Phone</td>
                        <td>@app.ExperienceYears Years</td>
                        <td><span class="badge badge-success">@app.Status</span></td>
                        <td>@app.AppliedDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(app.ResumePath))
                            {
                                <a href="@app.ResumePath" target="_blank" class="link-light">View</a>
                            }
                            else
                            {
                                <span class="text-muted">None</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <form asp-action="UpdateApplicationStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="applicationId" value="@app.ApplicationId" />
                                <input type="hidden" name="jobId" value="@Model.Job.JobId" />
                                <button type="submit" name="status" value="Rejected" class="btn btn-sm btn-danger me-1">Reject</button>
                            </form>
                            <form asp-action="DeleteApplication" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this application?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="applicationId" value="@app.ApplicationId" />
                                <input type="hidden" name="jobId" value="@Model.Job.JobId" />
                                <button type="submit" class="btn btn-sm btn-warning">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
