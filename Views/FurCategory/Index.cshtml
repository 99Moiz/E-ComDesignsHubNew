@model IEnumerable<FursonaHub.API.Models.Category>

@{
    ViewData["Title"] = "Fursona Categories";
}

<div class="row page-header mt-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold section-title mb-0">Fursona <span style="color:var(--brand-lime)">Categories</span></h2>
            <p class="text-secondary small mb-0">Manage product categories for the Fursona hub.</p>
        </div>
        <a asp-action="Create" class="btn btn-theme">
            <i class="bi bi-plus-lg"></i> Add Category
        </a>
    </div>
</div>

<div class="card app-card mt-4 p-4">
    <div class="table-responsive">
        <table class="table table-dark table-striped table-hover table-modern mb-0">
            <thead>
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Name</th>
                    <th scope="col">Sort Order</th>
                    <th scope="col">Active Status</th>
                    <th scope="col" class="text-center">Products</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-4">No categories found. Click "Add Category" to get started.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-bold text-white">@item.Name</td>
                            <td>@item.SortOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge bg-dark border border-secondary text-light">@item.Products?.Count</span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light me-2">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this category?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
