@model FursonaHub.API.Models.FAQ

@{
    ViewData["Title"] = "Add FAQ";
}

<div class="row page-header mt-4">
    <div class="col-12">
        <h2 class="fw-bold section-title">Add New <span style="color:var(--brand-lime)">FAQ</span></h2>
        <p class="text-secondary small">Create a question and answer card. Choose a category tag to bundle questions together.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-9 col-lg-8">
        <div class="card app-card p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="CategoryTag" class="form-label text-secondary fw-semibold">Category Tag / Group</label>
                    <input asp-for="CategoryTag" class="form-control" placeholder="e.g. Payments, Shipping, Fursuit Maintenance" required autocomplete="off" />
                    <span asp-validation-for="CategoryTag" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Question" class="form-label text-secondary fw-semibold">Question Text</label>
                    <input asp-for="Question" class="form-control" placeholder="e.g. Do you accept payment plans?" required />
                    <span asp-validation-for="Question" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Answer" class="form-label text-secondary fw-semibold">Answer Text</label>
                    <textarea asp-for="Answer" rows="5" class="form-control" placeholder="Write the complete answer response here..." required></textarea>
                    <span asp-validation-for="Answer" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SortOrder" class="form-label text-secondary fw-semibold">Display Sort Order</label>
                        <input asp-for="SortOrder" type="number" class="form-control" value="0" required />
                        <span asp-validation-for="SortOrder" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check form-switch card p-3 border-secondary w-100 mb-0" style="background-color: #141414; margin-left: 0;">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <label class="form-check-label text-white fw-semibold" for="IsActive">Is Active / Visible</label>
                                </div>
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActive" checked />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-action="Index" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-theme">
                        <i class="bi bi-save"></i> Save FAQ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
