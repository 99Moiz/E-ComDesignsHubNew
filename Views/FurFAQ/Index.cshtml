@model IEnumerable<FursonaHub.API.Models.FAQ>

@{
    ViewData["Title"] = "Fursona FAQs";
}

<div class="row page-header mt-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold section-title mb-0">Commission <span style="color:var(--brand-lime)">FAQs</span></h2>
            <p class="text-secondary small mb-0">Manage frequently asked questions related to terms of service, payment, and fursuit shipping.</p>
        </div>
        <a asp-action="Create" class="btn btn-theme">
            <i class="bi bi-plus-lg"></i> Add FAQ
        </a>
    </div>
</div>

<div class="card app-card mt-4 p-4">
    <!-- Group FAQs by Category Tag -->
    @if (!Model.Any())
    {
        <div class="text-center text-secondary py-4">No FAQs found. Click "Add FAQ" to get started.</div>
    }
    else
    {
        var groupedFaqs = Model.GroupBy(f => f.CategoryTag);
        foreach (var group in groupedFaqs)
        {
            <div class="mb-4">
                <h5 class="fw-bold text-success border-bottom border-secondary pb-2 mb-3">
                    <i class="bi bi-tag-fill me-2" style="font-size: 14px;"></i>@group.Key
                </h5>
                <div class="table-responsive">
                    <table class="table table-dark table-striped table-hover table-modern mb-0">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 30%;">Question</th>
                                <th scope="col" style="width: 45%;">Answer</th>
                                <th scope="col">Sort</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in group)
                            {
                                <tr>
                                    <td class="fw-bold text-white small">@item.Question</td>
                                    <td class="text-secondary small" style="white-space: pre-wrap;">@item.Answer</td>
                                    <td>@item.SortOrder</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light me-1">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this FAQ?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>
