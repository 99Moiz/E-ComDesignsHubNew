@model FursonaHub.API.Models.Product

@{
    ViewData["Title"] = "Edit Fursona Product";
}

<div class="row page-header mt-4">
    <div class="col-12">
        <h2 class="fw-bold section-title">Edit <span style="color:var(--brand-lime)">Product Info</span></h2>
        <p class="text-secondary small">Modify basic product details. Sizing specs, bullet point features, and extra gallery images can be managed from the "Manage Details" page.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-9 col-lg-8">
        <div class="card app-card p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label text-secondary fw-semibold">Product Title</label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Slug" class="form-label text-secondary fw-semibold">Slug</label>
                        <input asp-for="Slug" class="form-control" required />
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label text-secondary fw-semibold">Category</label>
                        <select asp-for="CategoryId" class="form-select form-control" asp-items="ViewBag.CategoryId" required></select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Price" class="form-label text-secondary fw-semibold">Price ($)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" required min="0" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="Rating" class="form-label text-secondary fw-semibold">Rating (1-5)</label>
                        <input asp-for="Rating" type="number" step="0.1" class="form-control" min="1" max="5" required />
                        <span asp-validation-for="Rating" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ShortDesc" class="form-label text-secondary fw-semibold">Short Description</label>
                    <textarea asp-for="ShortDesc" rows="2" class="form-control" required></textarea>
                    <span asp-validation-for="ShortDesc" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label text-secondary fw-semibold">Full Description</label>
                    <textarea asp-for="Description" rows="5" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SortOrder" class="form-label text-secondary fw-semibold">Display Sort Order</label>
                        <input asp-for="SortOrder" type="number" class="form-control" required />
                        <span asp-validation-for="SortOrder" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check form-switch card p-3 border-secondary w-100 mb-0" style="background-color: #141414; margin-left:0;">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <label class="form-check-label text-white fw-semibold" for="IsActive">Is Active / Visible</label>
                                </div>
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActive" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-theme">
                        <i class="bi bi-save"></i> Save Product Info
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
