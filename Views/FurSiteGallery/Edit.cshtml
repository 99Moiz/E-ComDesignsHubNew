@model FursonaHub.API.Models.SiteGallery

@{
    ViewData["Title"] = "Edit Showcase Photo";
}

<div class="row page-header mt-4">
    <div class="col-12">
        <h2 class="fw-bold section-title">Edit Showcase <span style="color:var(--brand-lime)">Photo Details</span></h2>
        <p class="text-secondary small">Modify image details or upload a new replacing image file.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-9 col-lg-7">
        <div class="card app-card p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label text-secondary fw-semibold">Current Image Thumbnail</label>
                    <div class="my-2">
                        <img src="@Model.ImageUrl" alt="@Model.AltText" class="img-thumbnail bg-dark border-secondary" style="max-height: 15rem; object-fit: contain; border-radius: 8px;" />
                    </div>
                    <label class="form-label text-secondary fw-semibold mt-2">Replace Image File (Optional)</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" />
                    <div class="text-muted small mt-1 fs-7">Only select a file here if you wish to overwrite the current showcase picture.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Caption" class="form-label text-secondary fw-semibold">Showcase Caption</label>
                    <input asp-for="Caption" class="form-control" required />
                    <span asp-validation-for="Caption" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AltText" class="form-label text-secondary fw-semibold">Alt Text (For screen readers / SEO)</label>
                    <input asp-for="AltText" class="form-control" required />
                    <span asp-validation-for="AltText" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SortOrder" class="form-label text-secondary fw-semibold">Display Sort Order</label>
                        <input asp-for="SortOrder" type="number" class="form-control" required />
                        <span asp-validation-for="SortOrder" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check form-switch card p-3 border-secondary w-100 mb-0" style="background-color: #141414; margin-left: 0;">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <label class="form-check-label text-white fw-semibold" for="IsActive">Is Active</label>
                                </div>
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActive" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-action="Index" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-theme">
                        <i class="bi bi-save"></i> Save Gallery Item
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
