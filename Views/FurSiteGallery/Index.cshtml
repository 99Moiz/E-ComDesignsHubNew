@model IEnumerable<FursonaHub.API.Models.SiteGallery>

@{
    ViewData["Title"] = "Fursona Site Gallery";
}

<div class="row page-header mt-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold section-title mb-0">Fursona <span style="color:var(--brand-lime)">Site Gallery</span></h2>
            <p class="text-secondary small mb-0">Manage general showcase photos and builders showcase assets displayed on the landing page.</p>
        </div>
        <a asp-action="Create" class="btn btn-theme">
            <i class="bi bi-plus-lg"></i> Add Showcase Photo
        </a>
    </div>
</div>

<div class="card app-card mt-4 p-4">
    <div class="table-responsive">
        <table class="table table-dark table-striped table-hover table-modern mb-0">
            <thead>
                <tr>
                    <th scope="col" style="width: 120px;">Image</th>
                    <th scope="col">Caption</th>
                    <th scope="col">Alt Text</th>
                    <th scope="col">Sort Order</th>
                    <th scope="col">Status</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-4">No gallery items found. Click "Add Showcase Photo" to get started.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@item.ImageUrl" alt="@item.AltText" class="img-thumbnail bg-dark border-secondary" style="width: 100px; height: 70px; object-fit: cover; border-radius: 6px;" />
                            </td>
                            <td class="text-white fw-bold">@item.Caption</td>
                            <td class="text-secondary small">@item.AltText</td>
                            <td>@item.SortOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Hidden</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light me-2">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this gallery item? This is non-reversible.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
