@model FursonaHub.API.Models.Testimonial

@{
    ViewData["Title"] = "Edit Testimonial";
}

<div class="row page-header mt-4">
    <div class="col-12">
        <h2 class="fw-bold section-title">Edit Client <span style="color:var(--brand-lime)">Testimonial</span></h2>
        <p class="text-secondary small">Modify details or replace customer avatar image.</p>
    </div>
</div>

<div class="row">
    <div class="col-md-9 col-lg-7">
        <div class="card app-card p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ClientName" class="form-label text-secondary fw-semibold">Client Name</label>
                        <input asp-for="ClientName" class="form-control" required />
                        <span asp-validation-for="ClientName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label text-secondary fw-semibold">Client Location</label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row align-items-center">
                    <div class="col-md-7 mb-3">
                        <label class="form-label text-secondary fw-semibold">Client Avatar Photo</label>
                        <div class="my-2">
                            <img src="@Model.AvatarUrl" alt="@Model.ClientName" class="rounded-circle border border-secondary" style="width: 60px; height: 60px; object-fit: cover;" />
                        </div>
                        <input type="file" name="avatarFile" class="form-control" accept="image/*" />
                        <div class="text-muted small mt-1 fs-7">Only select a file if you wish to change their avatar.</div>
                    </div>

                    <div class="col-md-5 mb-3">
                        <label asp-for="Rating" class="form-label text-secondary fw-semibold">Rating Score</label>
                        <select asp-for="Rating" class="form-select form-control" required>
                            <option value="5">★ ★ ★ ★ ★ (5 Stars)</option>
                            <option value="4">★ ★ ★ ★ (4 Stars)</option>
                            <option value="3">★ ★ ★ (3 Stars)</option>
                            <option value="2">★ ★ (2 Stars)</option>
                            <option value="1">★ (1 Star)</option>
                        </select>
                        <span asp-validation-for="Rating" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductRef" class="form-label text-secondary fw-semibold">Commission / Product Reference</label>
                    <input asp-for="ProductRef" class="form-control" />
                    <span asp-validation-for="ProductRef" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ReviewText" class="form-label text-secondary fw-semibold">Review Message</label>
                    <textarea asp-for="ReviewText" rows="4" class="form-control" required></textarea>
                    <span asp-validation-for="ReviewText" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SortOrder" class="form-label text-secondary fw-semibold">Sort Order</label>
                        <input asp-for="SortOrder" type="number" class="form-control" required />
                        <span asp-validation-for="SortOrder" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3 d-flex align-items-end">
                        <div class="form-check form-switch card p-3 border-secondary w-100 mb-0" style="background-color: #141414; margin-left: 0;">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <label class="form-check-label text-white fw-semibold" for="IsActive">Is Active</label>
                                </div>
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActive" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a asp-action="Index" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-theme">
                        <i class="bi bi-save"></i> Save Testimonial
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
