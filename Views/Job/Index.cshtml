@using EcommDesignsHub.Models
@model IEnumerable<Job>

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <h2 class="section-title">Jobs</h2>
    <a asp-action="Create" class="btn btn-theme mb-2 mb-md-0">+ Add New Job</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary">No jobs available. Add a job to get started.</div>
}
else
{
    <div class="row g-3">
        @foreach (var job in Model)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card app-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <h5 class="card-title mb-0">@job.Title</h5>
                            <span class="badge @((job.IsActive) ? "badge-success" : "badge-secondary")">@(job.IsActive ? "Active" : "Inactive")</span>
                        </div>
                        <p class="card-text text-muted">@job.JobType · @job.Location</p>
                        <p class="small mb-2">Experience: <strong>@job.ExperienceRequired Years</strong></p>
                        <p class="small text-muted">Posted: @job.PostedDate.ToString("yyyy-MM-dd")</p>
                        <div class="mt-auto d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@job.JobId" class="btn btn-outline-light btn-sm">Details</a>
                            <a asp-action="Applicants" asp-route-id="@job.JobId" class="btn btn-outline-info btn-sm">Applicants</a>
                            <a asp-action="Edit" asp-route-id="@job.JobId" class="btn btn-warning btn-sm">Edit</a>
                            <form asp-action="DeleteJob" method="post" class="d-grid" onsubmit="return confirm('Are you sure you want to delete this job and all its applications?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@job.JobId" />
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}