@using EcommDesignsHub.Models
@model IEnumerable<ProjectCategory>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold">
            Project <span style="color:var(--brand-lime)">Categories</span>
        </h2>

        <a asp-action="Createcategory" asp-controller="Project" class="btn btn-theme">
            + Add Category
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card project-card h-100 shadow p-4">

                    <div class="card-body p-0">
                        <h5 class="fw-bold text-white mb-2">
                            @item.Name
                        </h5>

                        <p class="text-secondary small mb-1">
                            Created: @item.CreatedAt.ToString("dd MMM yyyy")
                        </p>

                        <p class="text-secondary small">
                            By: @item.CreatedBy
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-3">

                            @if (item.IsActive == true)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }

                            <div>
                                <a asp-action="DeleteCategory" asp-controller="Project"
                                   asp-route-id="@item.Id"
                                   class="text-decoration-none me-3"
                                   style="color:var(--brand-lime)">
                                    Delete
                                </a>

                               
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>