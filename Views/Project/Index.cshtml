@using EcommDesignsHub.Models
@model IEnumerable<ProjectModel>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold">Our <span style="color:var(--brand-lime)">Portfolio</span></h2>
        <a asp-action="Create" class="btn btn-theme">+ Add Project</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card project-card h-100 shadow">
                    <img src="@item.ImgUrl" class="card-img-top" alt="@item.Title" />
                    <div class="card-body">
                        <h5 class="fw-bold text-white">@item.Title</h5>
                        <p class="text-secondary small">@item.Description</p>
                        <div class="d-flex justify-content-between mt-3">
                            @* <a  asp-action="Edit" asp-controller="Project"  asp-route-id="@item.Id" class="text-decoration-none" style="color:var(--brand-lime)">Edit →</a> *@
                            <a class="btn btn-sm btn-outline-danger border-0" asp-action="Delete" asp-route-id="@item.Id">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>