@model EcommDesignsHub.Models.ViewModel.UserListItemViewModel

@{
    ViewData["Title"] = "Delete User";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="app-card p-4 p-md-5">
            <h2 class="section-title mb-3">Delete User</h2>
            <p class="text-muted mb-4">Are you sure you want to delete this account?</p>

            <div class="alert alert-danger">
                <strong>@Model.Email</strong> will be permanently removed from the system.
            </div>

            <form asp-action="Delete" method="post">
                <input name="id" value="@Model.Id" type="hidden" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Index" class="btn btn-outline-light">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
