@model IEnumerable<EcommDesignsHub.Models.ViewModel.UserListItemViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h2 class="section-title mb-1">Users</h2>
        <p class="text-muted mb-0">Manage administrator accounts for the dashboard.</p>
    </div>
    <a asp-action="Create" class="btn btn-theme">Add User</a>
</div>

<div class="app-card p-3 p-md-4">
    <div class="table-responsive">
        <table class="table table-modern align-middle">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Email Confirmed</th>
                    <th>Lockout</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="badge badge-success">Confirmed</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Pending</span>
                            }
                        </td>
                        <td>
                            @if (user.LockoutEnabled)
                            {
                                <span class="badge badge-info">Enabled</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Disabled</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-light btn-sm me-2">Edit</a>
                            <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
